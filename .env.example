# ── Database (Neon) ──────────────────────────────────────────────────────────
# Full JDBC URL from Neon dashboard (includes ?sslmode=require)
DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=your_neon_user
DB_PASSWORD=your_neon_password

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6380
REDIS_PASSWORD=your_upstash_password
REDIS_SSL=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# ── Storage (S3-compatible: Cloudflare R2 / Backblaze B2 / Supabase) ─────────
MINIO_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=mawrid-attachments

# ── Mail (Gmail App Password) ─────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# ── Firebase ──────────────────────────────────────────────────────────────────
# Upload firebase-service-account.json as a Render Secret File
FIREBASE_CREDENTIALS_PATH=/etc/secrets/firebase-service-account.json

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated Vercel URLs for your frontends
CORS_ALLOWED_ORIGINS=https://mawrid-web.vercel.app,https://mawrid-admin.vercel.app
