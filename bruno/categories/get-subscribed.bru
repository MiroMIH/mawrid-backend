meta {
  name: Get Subscribed Categories (Supplier)
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/categories/subscribed
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  note: Login as SUPPLIER before calling this endpoint.
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("data is array", function() {
    expect(res.getBody().data).to.be.an("array");
  });
}
