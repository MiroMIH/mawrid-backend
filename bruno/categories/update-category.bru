meta {
  name: Update Category (Admin)
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/categories/{{categoryId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Matériaux de Construction - Modifié",
    "slug": "materiaux-construction-mod"
  }
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
