meta {
  name: Dashboard Stats
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/admin/stats
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("data exists", function() {
    expect(res.getBody().data).to.exist;
  });
}
