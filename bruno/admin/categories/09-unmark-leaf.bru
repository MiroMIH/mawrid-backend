meta {
  name: 09 - Unmark LEAF Node
  type: http
  seq: 9
}

patch {
  url: {{baseUrl}}/admin/categories/{{grandCategoryId}}/unmark-leaf
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("nodeType is ADMIN_CREATED", function() {
    expect(res.getBody().data.nodeType).to.equal("ADMIN_CREATED");
  });
}
