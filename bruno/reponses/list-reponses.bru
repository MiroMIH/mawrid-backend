meta {
  name: List Reponses for Demande
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/demandes/{{demandeId}}/reponses?page=0&size=20
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  note: Accessible by BUYER (owner) or ADMIN.
}

tests {
  test("status 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("data has content array", function() {
    expect(res.getBody().data.content).to.be.an("array");
  });
}
