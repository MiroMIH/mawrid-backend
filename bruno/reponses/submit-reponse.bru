meta {
  name: Submit Reponse (Supplier)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/demandes/{{demandeId}}/reponses
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "DISPONIBLE",
    "note": "Nous pouvons livrer dans un délai de 5 jours ouvrables. Prix unitaire: 1200 DZD/sac."
  }
}

docs {
  note: Login as SUPPLIER before calling this.
  status values: DISPONIBLE | INDISPONIBLE
}

script:post-response {
  if (res.getStatus() === 201) {
    bru.setEnvVar("reponseId", String(res.getBody().data.id));
  }
}

tests {
  test("status 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
  test("status is DISPONIBLE", function() {
    expect(res.getBody().data.status).to.equal("DISPONIBLE");
  });
  test("reponseId saved", function() {
    expect(bru.getEnvVar("reponseId")).to.exist;
  });
}
