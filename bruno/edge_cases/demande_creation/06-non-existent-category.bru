meta {
  name: 06-non-existent-category
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/buyer/demandes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{buyerToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Valid Title",
    "quantity": 100,
    "deadline": "2026-12-31",
    "categoryId": 9999,
    "wilaya": "16"
  }
}

tests {
  test("status 404 — category not found", function() {
    expect(res.getStatus()).to.equal(404);
  });
}
