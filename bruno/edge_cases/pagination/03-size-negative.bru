meta {
  name: Size Negative
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/buyer/demandes?size=-1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{buyerToken}}
}

docs {
  Spring Data auto-corrects size=-1 to a valid default (200).
  This tests that the API does not crash on negative pagination params.
}

tests {
  test("status 200 — Spring coerces invalid size to default", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
